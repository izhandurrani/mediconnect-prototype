# Public Configuration (Safe for frontend/Vite)
# These keys are exposed to the browser and are safe to be public (restricted via Google Cloud Console)
VITE_FIREBASE_API_KEY="your_public_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
VITE_FIREBASE_VAPID_KEY="your_vapid_key"

VITE_GEMINI_API_KEY="your_public_gemini_api_key"
VITE_GOOGLE_MAPS_API_KEY="your_public_google_maps_api_key"

# Private Configuration (DANGEROUS: MUST NOT BE PREFIXED WITH VITE_)
# These secrets MUST stay in the Node.js backend environment only.
# Wrap GOOGLE_PRIVATE_KEY in quotes to ensure newlines (\n) are read correctly.
GOOGLE_PROJECT_ID="your_project_id"
GOOGLE_CLIENT_EMAIL="your_client_email@your_project_id.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# Twilio IVR Configuration (server-side)
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="your_twilio_phone_number"
TWILIO_WEBHOOK_URL="https://your-functions-domain/twilioWebhook"
GEMINI_API_KEY="your_server_side_gemini_api_key"
